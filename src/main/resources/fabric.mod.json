{
	"schemaVersion": 1,
	"id": "betterhud",
	"version": "${version}",
	"name": "BetterHUD",
	"description": "A simple HUD with essential information easily accessible for Minecraft Fabric.",
	"authors": [
		"DSNS"
	],
	"contact": {
		"homepage": "https://dsns.dev"
	},
	"license": "AGPL-3.0",
	"icon": "assets/betterhud/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": ["dsns.betterhud.BetterHUD"],
		"modmenu": ["dsns.betterhud.ModMenu"]
	},
	"mixins": [
		"betterhud.mixins.json"
	],
	"depends": {
		"fabricloader": "${loaderReq}",
		"minecraft": "${minecraftReq}",
		"java": "${javaReq}"${dependsExtra}
	},
	"suggests": {
		"modmenu": "*"
	}
}
